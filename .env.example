# Bastion environment configuration — copy to `.env` and fill in real values.
# NEVER commit the real `.env` file (it is git-ignored). This file must only
# ever contain placeholder values — never a real secret, key, or passphrase.

# --- CLI-05: Connection & keystore configuration ---

# Solana JSON-RPC HTTP endpoint (Helius or another provider).
SOLANA_RPC=https://your-rpc-provider.example/your-api-key

# Solana JSON-RPC WebSocket endpoint (for logsSubscribe/accountSubscribe).
SOLANA_WS=wss://your-rpc-provider.example/your-api-key

# Base58-encoded vault secret key. This funds session wallets and is loaded
# ONLY for funding operations — sweeps target VAULT_PUBKEY and never need
# this value. Treat as highly sensitive; never log or transmit it.
VAULT_SECRET=PLACEHOLDER_BASE58_SECRET_KEY

# Base58-encoded public key of the vault. Sweep destinations always resolve
# to this address.
VAULT_PUBKEY=PLACEHOLDER_BASE58_PUBLIC_KEY

# Directory holding encrypted session-wallet keystore files (0600 perms,
# never cloud-synced — see .gitignore's keystore/ entry).
KEYSTORE_DIR=./keystore

# Passphrase used to derive the keystore's Scrypt/Fernet encryption key.
# If left unset, Bastion prompts interactively via getpass at runtime —
# do NOT set this in a shared/committed environment (D-02).
KEYSTORE_PASSPHRASE=

# Telegram bot token for out-of-band alerting (separate identity from any
# trading-session bot, so a compromised session can't suppress alerts).
TELEGRAM_BOT_TOKEN=PLACEHOLDER_TELEGRAM_BOT_TOKEN

# Telegram chat ID that receives alerts.
TELEGRAM_CHAT_ID=PLACEHOLDER_TELEGRAM_CHAT_ID

# Pushover application token (optional alternate/additional alert channel).
PUSHOVER_TOKEN=PLACEHOLDER_PUSHOVER_TOKEN

# Pushover user key (optional alternate/additional alert channel).
PUSHOVER_USER=PLACEHOLDER_PUSHOVER_USER

# --- CLI-06: Safety rails ---

# Maximum lamports/SOL a session wallet may ever hold (the "cap" that bounds
# blast radius). Conservative non-zero default enforced in code if unset.
MAX_SESSION_CAP=0.5

# Lamports reserved for transaction fees, held back from sweep calculations
# so a sweep never fails for lack of fee funds.
FEE_RESERVE_LAMPORTS=5000

# Behavior score threshold (0-100) at which Bastion sends a "watch" level
# alert (informational, non-critical).
SCORE_WATCH_THRESHOLD=40

# Behavior score threshold (0-100) at which Bastion sends a "critical" alert
# (and triggers auto-sweep if armed).
SCORE_CRITICAL_THRESHOLD=75
